# Copy to .env and fill in values for your Supabase project.
# Supabase Dashboard → Project → Settings → API / Database

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres

# Supabase project credentials
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# External services
# ODESLI_API_KEY=your-odesli-key        # optional — higher rate limit at odesli.co
YOUTUBE_API_KEY=your-youtube-data-api-v3-key  # console.cloud.google.com → YouTube Data API v3

# CORS: comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
