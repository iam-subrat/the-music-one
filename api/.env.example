# Copy to .env and fill in values for your Supabase project.
# Supabase Dashboard → Project → Settings → API / Database

# PostgreSQL connection string — raw password ok, special chars (@,$,#) need no escaping
# Use pgBouncer transaction-mode pooler (port 6543) for deployed envs to avoid session-pool exhaustion.
# Supabase Dashboard → Project → Settings → Database → Connection pooling → "Transaction" mode URL.
# Alembic auto-rewrites :6543 → :5432 (session mode) for migrations.
# Local dev: direct connection (port 5432) is fine.
DATABASE_URL=postgresql://postgres.PROJECT_REF:your-db-password@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase project credentials
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# External services
# ODESLI_API_KEY=your-odesli-key        # optional — higher rate limit at odesli.co
YOUTUBE_API_KEY=your-youtube-data-api-v3-key  # console.cloud.google.com → YouTube Data API v3
SPOTIFY_CLIENT_ID=your-spotify-client-id        # developer.spotify.com → Dashboard → App
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# CORS: comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Frontend URL — post-auth redirect target
FRONTEND_URL=http://localhost:5173

# Reverse-proxy path prefix (Nginx strips it before forwarding).
# Leave empty if app served at root. Example: /musicone-staging
ROOT_PATH=

# Cookie Domain — set when API + frontend share eTLD+1 (e.g. .themusic.one).
# Leave empty for host-only cookies (local dev / cross-site setup).
COOKIE_DOMAIN=

# Cookie SameSite: lax (same-site / subdomain), none (cross-site, requires Secure).
COOKIE_SAMESITE=lax
