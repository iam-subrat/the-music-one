# API base URL — leave empty for local dev (Vite proxies /api → localhost:8000).
# Set to FastAPI public URL in production, e.g. https://api.yourdomain.com
# VITE_API_URL=

# Feature flags default to safe values in vite.config.js — override here if needed.
# FLAG_JAM_SESSION=true

# PostHog analytics (https://posthog.com — free cloud tier)
# VITE_POSTHOG_KEY=phc_your_key_here
# VITE_APP_ENV=staging   # set per deployment: staging | production (defaults to Vite MODE)
